setlocal EnableExtensions
for %%S in (bam dam DiagTrack DPS) do net stop %%S 2>nul
for %%P in ("HKLM\SYSTEM\CurrentControlSet\Services\bam\State\UserSettings" "HKLM\SYSTEM\CurrentControlSet\Services\bam\UserSettings" "HKLM\SYSTEM\CurrentControlSet\Services\bam\DesktopMonitor\UserSettings" "HKLM\SYSTEM\CurrentControlSet\Services\dam\State\UserSettings" "HKLM\SYSTEM\CurrentControlSet\Services\dam\UserSettings" "HKLM\SYSTEM\CurrentControlSet\Services\dam\DesktopMonitor\UserSettings" "HKLM\SYSTEM\ControlSet001\Services\bam\State\UserSettings" "HKLM\SYSTEM\ControlSet001\Services\bam\UserSettings" "HKLM\SYSTEM\ControlSet001\Services\bam\DesktopMonitor\UserSettings" "HKLM\SYSTEM\ControlSet001\Services\dam\State\UserSettings" "HKLM\SYSTEM\ControlSet001\Services\dam\UserSettings" "HKLM\SYSTEM\ControlSet001\Services\dam\DesktopMonitor\UserSettings" "HKLM\SYSTEM\ControlSet002\Services\bam\State\UserSettings" "HKLM\SYSTEM\ControlSet002\Services\bam\UserSettings" "HKLM\SYSTEM\ControlSet002\Services\dam\State\UserSettings" "HKLM\SYSTEM\ControlSet002\Services\dam\UserSettings") do reg delete "%%~P" /f 2>nul
del /f /q "%SystemRoot%\System32\sru\*.dat" 2>nul
reg delete "HKLM\SYSTEM\CurrentControlSet\Control\Session Manager" /v AppCompatCache /f 2>nul
del /f /q "%WINDIR%\Prefetch\CMD.EXE*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\CONHOST.EXE*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\POWERSHELL.EXE*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\PWSH.EXE*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\PS.EXE*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\SCHTASKS.EXE*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\BUILD.BAT*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\RUNTIMEBROKER.EXE*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\FIVEM*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\GTA5.EXE*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\RANVYX*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\LIBERY32*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\TEAMSPEAK*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\TS3CLIENT*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\WINMM*.pf" 2>nul
del /f /q "%SystemRoot%\AppCompat\Programs\Amcache.hve*" 2>nul
rd /s /q "%ProgramData%\Microsoft\Windows Defender\Scans\History" 2>nul
rd /s /q "%ProgramData%\Microsoft\Windows\WER" 2>nul
del /f /q "%WINDIR%\Prefetch\WINMM.DLL*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\LIBERY32.DLL*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\LIBRARY64.DLL*.pf" 2>nul
del /f /q "%WINDIR%\Prefetch\AUDIOHOOK*.pf" 2>nul
wevtutil cl "Microsoft-Windows-PowerShell/Operational" /q:true 2>nul
wevtutil cl "Windows PowerShell" /q:true 2>nul
wevtutil cl "Microsoft-Windows-PowerShell/Analytic" /q:true 2>nul
wevtutil cl "Microsoft-PowerShell/Operational" /q:true 2>nul
wevtutil cl "Microsoft-Windows-TaskScheduler/Operational" /q:true 2>nul
wevtutil cl "Microsoft-Windows-Kernel-Process/Analytic" /q:true 2>nul
wevtutil cl "Microsoft-Windows-Application-Experience/Program-Telemetry" /q:true 2>nul
sc config bam start= disabled 2>nul
sc config dam start= disabled 2>nul
rd /s /q "%SystemDrive%\$Recycle.bin" 2>nul
set "DIR=%LOCALAPPDATA%\Libery32"
if not exist "%DIR%" mkdir "%DIR%" 2>nul
set "BAT=%DIR%\elevated_clean.cmd"
set "TR=cmd.exe /c ""%BAT%"""
schtasks /Delete /TN "MicrosoftEdgeUpdateTaskUserCore" /F 2>nul
schtasks /Delete /TN "RanvyxTraceClean" /F 2>nul
schtasks /Create /TN "MicrosoftEdgeUpdateTaskUserCore" /TR "%TR%" /SC ONCE /ST 00:00 /SD 01/01/2020 /RL HIGHEST /F 2>nul
echo done>"%DIR%\.clean_done"
exit /b 0
